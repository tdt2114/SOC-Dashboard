APP_NAME=soc-dashboard-api
APP_ENV=development
MOCK_MODE=true
CORS_ORIGINS=http://localhost:3000
VERIFY_TLS=false
API_TIMEOUT_SECONDS=10
INDEXER_TIMEOUT_SECONDS=10
DEFAULT_TIME_RANGE=24h
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

POSTGRES_DB=soc_dashboard
POSTGRES_USER=soc_dashboard
POSTGRES_PASSWORD=soc_dashboard_dev
POSTGRES_HOST=soc-postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://soc_dashboard:soc_dashboard_dev@soc-postgres:5432/soc_dashboard
JWT_SECRET_KEY=change-this-dev-secret
JWT_REFRESH_SECRET_KEY=change-this-dev-refresh-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
SEED_DEFAULT_DEPARTMENT_CODE=SOC
SEED_DEFAULT_DEPARTMENT_NAME=Security Operations Center
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@local.test
SEED_ADMIN_PASSWORD=Admin123!ChangeMe
SEED_ADMIN_FULL_NAME=SOC Admin
SEED_SUPERADMIN_USERNAME=superadmin
SEED_SUPERADMIN_EMAIL=superadmin@local.test
SEED_SUPERADMIN_PASSWORD=Tt12345678
SEED_SUPERADMIN_FULL_NAME=SOC Super Admin

# When MOCK_MODE=true, Repo B uses fixture data and can be tested without Repo A.
# Set MOCK_MODE=false to test live integration against Repo A.
#
# Default values below assume Repo A is running separately on the same Docker host.
# If Repo B is attached to the same compose network as Repo A, switch these hosts to:
# WAZUH_API_BASE_URL=https://wazuh-manager:55000
# WAZUH_INDEXER_URL=https://wazuh-indexer:9200
WAZUH_API_BASE_URL=https://host.docker.internal:55000
WAZUH_API_USERNAME=wazuh-wui
WAZUH_API_PASSWORD=MyApiSecret456!
WAZUH_INDEXER_URL=https://host.docker.internal:9200
WAZUH_INDEXER_USERNAME=admin
WAZUH_INDEXER_PASSWORD=SecurePassword123!
WAZUH_ALERT_INDEX_PATTERN=wazuh-alerts-*

API_BASE_URL=http://soc-backend:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
